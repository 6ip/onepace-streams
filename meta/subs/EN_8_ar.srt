1
00:00:00,000 --> 00:00:03,000
{\an8}<b><font color="#9CD5FF">One Pace Premium</font></b>
Keep the project alive: <font color="#a8c7fa">ko-fi.com/not6ip</font>

2
00:01:54,230 --> 00:01:56,600
أتوا كلّ هذه المسافة بعد تجاوزهم لأكوا لاغونا

3
00:01:56,600 --> 00:01:58,600
إنّه لأمر مذهل بالفعل

4
00:01:59,470 --> 00:02:01,260
يبدو أنّهم محظوظون على الأقلّ

5
00:02:01,260 --> 00:02:03,590
هذه المرّة، لدينا الإذن بقتلهم

6
00:02:03,590 --> 00:02:06,570
الأمر أسهل عندما لا يكون علينا 
القلق بشأن التّهاون معهم

7
00:02:07,540 --> 00:02:08,590
الجسر المتحرّك؟

8
00:02:08,590 --> 00:02:12,020
نعم، إنّ عائلة فرانكي تقاتل حاليًّا لإنزاله

9
00:02:12,710 --> 00:02:16,690
بمجرّد أن ينزل، سيكون بإمكاننا 
الذّهاب للجانب الآخر في الحال

10
00:02:16,690 --> 00:02:19,750
...يا إلهي... رغم أنّه أمامنا مباشرة

11
00:02:29,820 --> 00:02:31,210
...أيّتها الغبيّة

12
00:02:31,210 --> 00:02:36,020
سُحقًا، ما مدى ثقل العبء الّذي 
تحمله هذه المرأة بالضّبط؟

13
00:02:37,480 --> 00:02:40,550
اسمعوا أيّها السّي بي 9

14
00:02:40,550 --> 00:02:44,020
أمنحكم الإذن بقتلهم، لكن افعلوا 
ذلك هنا في برج القانون

15
00:02:45,780 --> 00:02:48,980
أهمّ الأشياء على الإطلاق هي حياتي وترقيتي

16
00:02:49,760 --> 00:02:56,320
إن سمحت لهم بفعل ما يحلوا لهم
فمن سيحميني عند حدوث أمر ما؟

17
00:02:59,050 --> 00:03:00,840
أيّها القراصنة الأغبياء

18
00:03:00,840 --> 00:03:06,260
اعلموا جيّدًا أنّ التّظاهر بالشّجاعة 
لا يغيّر من الأمر شيئًا

19
00:03:07,050 --> 00:03:11,520
ستواجهون قوّة مجموعة الاغتيال سي بي 9

20
00:03:11,520 --> 00:03:16,200
وثقل بوّابات العدالة الّتي لا يمكن 
فتحها بالقوّة البشريّة

21
00:03:16,200 --> 00:03:17,600
...وفوق كلّ ذلك

22
00:03:17,600 --> 00:03:25,560
لديّ الآن "السّلطة لتنفيذ "نداء الدّمار
باستعمال حلزون الاتّصال الذّهبيّ هذا

23
00:03:26,490 --> 00:03:27,980
..."نداء الدّمار"

24
00:03:27,980 --> 00:03:30,290
هذا صحيح

25
00:03:30,290 --> 00:03:32,620
القوّة الّتي سحقت مسقط رأسك

26
00:03:32,620 --> 00:03:37,540
قبل عشرين سنة بالضّبط يا نيكو روبين

27
00:03:37,540 --> 00:03:42,920
أذكر أنّه في السّنة التّالية، مُحي
اسم أوهارا من على الخريطة

28
00:03:42,920 --> 00:03:45,630
مسقط رأس روبين؟

29
00:03:45,630 --> 00:03:47,500
ذلك المقنّع اللّعين

30
00:03:48,310 --> 00:03:52,750
لا أملك أيّ مكان آخر للذّهاب أو العودة إليه

31
00:03:53,400 --> 00:03:54,680
إيّاك

32
00:03:54,680 --> 00:03:56,500
إلاّ ذلك

33
00:03:57,560 --> 00:04:00,650
،أعجبتني ردّة الفعل هذه
أشعرتني بالقشعريرة

34
00:04:01,260 --> 00:04:05,310
ماذا؟ هل يعني هذا أنّك تريدين
منّي الضّغط على هذا الزّرّ

35
00:04:05,310 --> 00:04:07,440
لتفعيل "نداء الدّمار"؟ أليس كذلك؟

36
00:04:09,580 --> 00:04:13,910
هل تدرك بالفعل ما الّذي سيحدث 
إن ضغطت عليه؟

37
00:04:13,910 --> 00:04:20,840
نعم، سأقضي على احتماليّة هروب 
القراصنة من هذه الجزيرة

38
00:04:20,840 --> 00:04:23,290
بضغطة زرّ واحدة

39
00:04:23,290 --> 00:04:25,480
الأمر بتلك البساطة

40
00:04:25,480 --> 00:04:27,630
لا شيء في ذلك بسيط

41
00:04:27,630 --> 00:04:31,810
هل تتذكّرين شيئًا ما؟

42
00:04:31,810 --> 00:04:34,820
هل أحاول الضّغط عليه إن أردتِ؟

43
00:04:35,260 --> 00:04:37,020
هنا والآن؟

44
00:04:41,470 --> 00:04:43,280
ما الّذي تفعله؟ توقّف

45
00:04:46,260 --> 00:04:48,830
تتحدّثين بتعالٍ بالفعل، صحيح؟

46
00:05:06,200 --> 00:05:10,090
قلتَ أنّ أوهارا قد مُحيت من على الخريطة

47
00:05:10,090 --> 00:05:13,110
هل يمكنك رؤية البشر على الخريطة؟

48
00:05:13,110 --> 00:05:16,940
...لأنّكم ترون العالم بتلك الطّريقة

49
00:05:17,480 --> 00:05:20,310
تصبح الأعمال الشّنيعة كهذه هيّنة عليكم

50
00:05:29,730 --> 00:05:33,990
إنّ "نداء الدّمار" قوّة معدومة الرّحمة
تجعل المرء يغفل عن أهدافه

51
00:05:34,850 --> 00:05:37,160
لا يجب أن تستعمله. إلاّ ذلك

52
00:05:37,850 --> 00:05:40,560
!أبدًا...! إلاّ ذلك

53
00:05:52,840 --> 00:05:54,140
روبين هناك

54
00:05:54,140 --> 00:05:55,760
نالوا منها

55
00:05:57,460 --> 00:05:58,270
هذا مؤلم

56
00:05:59,010 --> 00:06:00,950
أجل

57
00:06:00,950 --> 00:06:03,010
أيّتها الوحش

58
00:06:03,010 --> 00:06:03,860
أنت مقرفة

59
00:06:05,280 --> 00:06:10,150
!وحش! وحش! وحش! وحش

60
00:06:13,620 --> 00:06:17,660
ضربتني الوحش

61
00:06:17,660 --> 00:06:19,740
إنّها بغيضة

62
00:06:19,740 --> 00:06:21,610
سننال منك على هذا

63
00:06:46,240 --> 00:06:47,180
اسمعي يا هذه

64
00:06:51,220 --> 00:06:55,440
أتى أبنائي وهم يبكون للمنزل
ويقولون أنّك ضربتهم بلا سبب

65
00:06:56,090 --> 00:06:58,800
لا تقتربي من أبنائي

66
00:06:58,800 --> 00:07:00,800
لِمَ لا تقولين أيّ شيء؟

67
00:07:00,800 --> 00:07:04,550
يا إلهي... إنّك فتاة بغيضة بالفعل

68
00:07:06,560 --> 00:07:08,050
مهلاً، انتظري

69
00:07:08,050 --> 00:07:10,470
لم أنتهِ منك بعد

70
00:07:18,620 --> 00:07:21,790
أخبريني يا أمّي، ما العشاء اللّيلة؟

71
00:07:21,790 --> 00:07:22,650
ماذا تريدين أكله؟

72
00:07:22,650 --> 00:07:25,150
...لحظة... لحظة

73
00:07:25,150 --> 00:07:26,320
عجّة بيض بالأرزّ

74
00:07:27,590 --> 00:07:29,550
أنت تحبّين عجّة البيض بالأرزّ كثيرًا، صحيح؟

75
00:07:29,550 --> 00:07:30,340
نعم

76
00:07:30,340 --> 00:07:32,790
سيكون علينا إذًا شراء الكثير من البيض

77
00:07:32,790 --> 00:07:34,310
مرحى

78
00:07:42,910 --> 00:07:47,080
لقد عدت، أنا آسفة على التّأخّر

79
00:07:47,720 --> 00:07:49,380
أيّتها العمّة روجي؟

80
00:07:59,710 --> 00:08:02,330
"...إلى روبين. إنّ اليوم"

81
00:08:02,330 --> 00:08:04,420
هو عيد ميلاد ابنتي

82
00:08:04,420 --> 00:08:09,080
لذلك قرّرنا نحن الثّلاثة 
الخروج للعشاء كعائلة

83
00:08:09,870 --> 00:08:13,700
ثمّة بعض الخبز، لذلك تناوليه على العشاء

84
00:08:14,120 --> 00:08:17,710
لا تستعملي الكثير من المربّى

85
00:08:17,710 --> 00:08:23,430
وبعد العشاء وقبل أن نعود
اغسلي الأطباق ونظّفي المنزل

86
00:08:23,430 --> 00:08:28,690
واجمعي الغسيل واصعدي للأعلى باكرًا

87
00:08:36,140 --> 00:08:39,140
أخبريني يا أمّي، ما العشاء اللّيلة؟

88
00:08:39,140 --> 00:08:40,650
ماذا تريدين أكله؟

89
00:08:40,650 --> 00:08:43,460
...لحظة... لحظة

90
00:08:43,460 --> 00:08:44,870
عجّة بيض بالأرزّ

91
00:08:45,930 --> 00:08:47,790
أنت تحبّين عجّة البيض بالأرزّ كثيرًا، صحيح؟

92
00:08:47,790 --> 00:08:48,570
نعم

93
00:08:48,570 --> 00:08:50,880
سيكون علينا إذًا شراء الكثير من البيض

94
00:08:50,880 --> 00:08:52,570
مرحى

95
00:09:12,060 --> 00:09:15,360
!ها هي هناك! لقد وصلت روبين

96
00:09:15,360 --> 00:09:17,280
يبدو أنّها أتت لتعيد الكتاب

97
00:09:17,280 --> 00:09:18,980
ليأخذ الجميع مكانهم

98
00:09:23,760 --> 00:09:28,340
،مساء الخير أيّها الأستاذ كلوفر
أتيت لأعيد الكتاب الّذي استعرته

99
00:09:32,300 --> 00:09:33,830
...استعداد

100
00:09:33,830 --> 00:09:37,550
تهانينا يا روبين

101
00:09:37,550 --> 00:09:39,660
أنت مذهلة يا روبين

102
00:09:39,660 --> 00:09:40,840
هذا متوقّع من عبقريّة

103
00:09:40,840 --> 00:09:43,340
أحضرنا كعكة من أجلك

104
00:09:43,340 --> 00:09:47,000
روبين، إنّ امتحان شهادة الدّكتوراه
...الّذي خضته ذلك اليوم

105
00:09:47,000 --> 00:09:49,080
حقّقتِ فيه 100% بشكل ممتاز

106
00:09:49,080 --> 00:09:52,270
وبالتّالي، نعترف بك كعالِمة آثار بدءًا من اليوم

107
00:09:52,950 --> 00:09:58,320
أصبحت واحدة منّا الآن وسنقوم بالأبحاث معًا

108
00:09:59,280 --> 00:10:03,250
،تفضّلي، هذا يثبت أنّك عالِمة
خذيه يا روبين

109
00:10:04,080 --> 00:10:05,610
أنا سعيد من أجلك يا روبين

110
00:10:05,610 --> 00:10:07,190
تهانينا

111
00:10:08,500 --> 00:10:13,710
اسمعي يا روبين، عليك أن تفهمي جيّدًا 
ما يعنيه أن تكوني عالمة آثار

112
00:10:13,710 --> 00:10:16,210
نعم أيّها الأستاذ كلوفر

113
00:10:17,030 --> 00:10:20,430
الماضي هو منبع المعرفة

114
00:10:20,430 --> 00:10:25,380
عمر شجرة المعرفة هذه هو 5000 سنة

115
00:10:25,380 --> 00:10:27,840
تمّ جمع كمّيّات هائلة من 
المؤلّفات في هذه الشّجرة

116
00:10:27,840 --> 00:10:30,440
من كلّ بقاع العالم وعلى مدى 
وقت طويل جدًّا

117
00:10:30,440 --> 00:10:36,070
إنّها كنز لا غنى عنه لكلّ البشريّة

118
00:10:36,070 --> 00:10:40,030
هذه أكبر وأقدم مكتبة في العالم
وتشكّل المعرفة مصدر فخرها

119
00:10:40,030 --> 00:10:43,650
ويجتمع علماء آثار كبار 
من كلّ أنحاء العالم

120
00:10:43,650 --> 00:10:45,670
تحت شجرة المعرفة هذه

121
00:10:45,670 --> 00:10:49,460
وعند استعمال هذه الكتب

122
00:10:49,460 --> 00:10:52,760
فلا يوجد لغز تاريخيّ لا يمكننا حلّه

123
00:10:53,700 --> 00:10:55,440
أفهمتِ يا روبين؟

124
00:10:55,440 --> 00:10:56,720
نعم

125
00:10:56,720 --> 00:11:03,850
أودّ رؤيتك تقدّمين مساهمتك للعالم 
بالبحث في مختلف الثّقافات

126
00:11:03,850 --> 00:11:08,060
"أيّها الأستاذ، أودّ حلّ لغز "التّاريخ الفارغ

127
00:11:08,060 --> 00:11:12,860
لا... لا! لا تفعلي! أمنعك من 
كما فعلتُ دائمًا

128
00:11:12,860 --> 00:11:16,990
ماذا؟ لماذا؟ إن بحثنا في البونغليف

129
00:11:16,990 --> 00:11:19,700
فسنعرف ما حدث خلال "القرن الفارغ"، صحيح؟

130
00:11:21,300 --> 00:11:23,410
لماذا تعرفين كلّ هذا؟

131
00:11:23,410 --> 00:11:27,360
هل تلصّصت على القبو باستعمال قدراتك؟

132
00:11:27,360 --> 00:11:28,160
...لكن

133
00:11:28,160 --> 00:11:33,130
عليك أن تدركي أنّ فكّ رموز 
البونغليف فعل إجراميّ

134
00:11:35,450 --> 00:11:37,080
...لكن

135
00:11:37,080 --> 00:11:39,370
أنتم تبحثون في أمر البونغليف

136
00:11:39,370 --> 00:11:41,560
في القبو في وقت متأخّر من اللّيل

137
00:11:41,560 --> 00:11:45,230
روبين، كيف تعرفين ذلك؟

138
00:11:46,050 --> 00:11:49,900
اشرحي ما يحدث! هل تقولين
أنّك كنتِ تتجسّسين علينا أيضًا؟

139
00:11:50,970 --> 00:11:52,560
أجيبيني يا روبين

140
00:11:53,960 --> 00:11:55,250
...هذا لأنّكم

141
00:11:56,400 --> 00:12:00,030
ترفضون السّماح لي بدخول الغرفة 
حتّى إن أتيتُ وطلبتُ منكم الإذن

142
00:12:01,340 --> 00:12:08,250
لذلك... ظننت أنّكم ستسمحون لي بأن
أصبح جزءًا من بحثكم إن صرت عالمة آثار

143
00:12:09,040 --> 00:12:11,100
فدرست بجدّ

144
00:12:12,890 --> 00:12:14,140
...روبين

145
00:12:17,000 --> 00:12:22,850
صحيح أنّك اكتسبت معرفة كافية
لتصبحي عالِمة

146
00:12:22,850 --> 00:12:25,940
لكنّك ما زلت طفلة

147
00:12:25,940 --> 00:12:29,650
سيُعدموننا إن اكتشفوا ما نفعله

148
00:12:29,650 --> 00:12:32,580
إنّنا نقوم بالأمر مدركين تمامًا للمخاطر

149
00:12:32,580 --> 00:12:36,810
منذ أن أصبح هذا قانونًا قبل 800 سنة

150
00:12:36,810 --> 00:12:41,370
كان هنالك في الحقيقة العديد
من العلماء الّذين فقدوا حياتهم

151
00:12:42,170 --> 00:12:44,540
هذه فرصة جيّدة، لذلك دعيني أخبرك بهذا

152
00:12:45,150 --> 00:12:49,160
نحن في أوهارا الوحيدون في التّاريخ

153
00:12:49,160 --> 00:12:51,760
ممّن تمكّنوا من فكّ رموز النّصوص القديمة

154
00:12:52,790 --> 00:12:55,220
لا يمكننا التّراجع

155
00:12:55,790 --> 00:12:57,590
أقسمي على شجرة المعرفة

156
00:12:57,590 --> 00:12:59,550
إن حاولت الاقتراب من القبو ثانية

157
00:12:59,550 --> 00:13:06,180
سأمنعك من دخول مختبر 
الأبحاث والمكتبة، أهذا مفهوم؟

158
00:13:09,960 --> 00:13:10,870
روبين

159
00:13:11,990 --> 00:13:15,630
إنّها تسير على خطى والدتها بكلّ الطّرق

160
00:13:15,630 --> 00:13:19,070
ما زالت لا تعرف بشأن حادثة ذلك اليوم

161
00:13:20,380 --> 00:13:24,050
إنّ أولفيا والدة روبين، قد قُبض عليها

162
00:13:24,050 --> 00:13:27,870
واضح ما الّذي يخفيه القدر لها

163
00:14:17,800 --> 00:14:19,700
...ما... ماء

164
00:14:22,140 --> 00:14:23,510
مومياء؟

165
00:14:32,180 --> 00:14:33,630
هذا لذيذ

166
00:14:42,990 --> 00:14:45,480
...نجوت بطريقة ما

167
00:14:46,310 --> 00:14:49,550
أتساءل إن كانت بخير أيضًا

168
00:14:51,260 --> 00:14:54,930
لم تعد حياتي في خطر الآن. شكرًا لك

169
00:14:54,930 --> 00:14:57,660
هل هنالك بلدة أو ما شابه على هذه الجزيرة؟

170
00:14:57,660 --> 00:14:59,320
نعم

171
00:14:59,320 --> 00:15:01,510
فهمت

172
00:15:03,380 --> 00:15:07,680
إن كانت الأمواج ستجرفني لمكان ما
لفضّلت أن تكون جزيرة غير مأهولة

173
00:15:15,530 --> 00:15:18,860
بإمكانك البقاء هنا إن أردت
لكن لن يحدث أيّ شيء

174
00:15:19,530 --> 00:15:24,530
ساقي مصابة، لذلك سألزم مكاني

175
00:15:25,370 --> 00:15:29,950
أنوي بناء طوف أو ما شابه
وأغادر هذا المكان في النّهاية

176
00:15:31,700 --> 00:15:33,910
هذه أوّل مرّة ترين فيها عملاقًا؟

177
00:15:33,910 --> 00:15:34,910
نعم

178
00:15:35,850 --> 00:15:41,350
لكن اسمعي، لا تضعيني في نفس
الكفّة مع أولئك من إلباف

179
00:15:41,350 --> 00:15:45,090
توجد قبائل عمالقة مسالمة أيضًا

180
00:15:45,090 --> 00:15:46,970
...فهمت

181
00:15:48,360 --> 00:15:51,610
أعلم أنّك قد لا تستمعين لكلامي
لكنّني سأسألك في كلّ الأحوال

182
00:15:51,610 --> 00:15:56,900
لا أريدك أن تخبري أيّ أحد 
بشأني عندما تعودين للمنزل

183
00:15:56,900 --> 00:15:58,570
حسنًا

184
00:15:59,720 --> 00:16:03,150
كان ذلك سهلاً جدًّا، ستخبرهم بالتّأكيد

185
00:16:03,910 --> 00:16:05,070
لن أخبر أحدًا

186
00:16:09,480 --> 00:16:14,250
هذه كذبة، مستحيل أن تحتفظ
هذه الطّفلة بسرّ كهذا

187
00:16:15,130 --> 00:16:18,290
لن أخبر أحدًا لأنّني لست مهتمّة بك

188
00:16:35,150 --> 00:16:36,670
ديريشي"؟"

189
00:16:36,670 --> 00:16:37,770
ما معنى ذلك؟

190
00:16:38,640 --> 00:16:41,890
ماذا تقصدين؟ تلك ضحكتي فحسب

191
00:16:44,070 --> 00:16:45,450
أنت تضحك؟

192
00:16:46,070 --> 00:16:48,840
أنت طفلة مرحة

193
00:16:53,010 --> 00:16:54,290
ضحكتك غريبة

194
00:16:57,630 --> 00:17:02,550
لطالما قيل لي أنّ ضحكتي ليست جيّدة

195
00:17:02,550 --> 00:17:05,430
أنت ظريفة عندما تضحكين

196
00:17:06,350 --> 00:17:08,790
عليك أن تضحكي أكثر

197
00:17:11,050 --> 00:17:16,610
اسمي ساول، هاغوار د. ساول

198
00:17:16,610 --> 00:17:17,810
دِ؟

199
00:17:17,810 --> 00:17:25,210
نعم، لا أعرف السّبب، لكنّ الجميع في عائلتي 
يحملون ذلك الحرف في أسمائهم

200
00:17:25,210 --> 00:17:26,290
ما اسمك أنت؟

201
00:17:26,290 --> 00:17:27,920
روبين

202
00:17:27,920 --> 00:17:33,500
هكذا إذًا، لأصدقك القول يا روبين
أنا مُلاحَق الآن

203
00:17:33,500 --> 00:17:35,950
لذلك سأقع في المشكلات إن وجدني الآخرون

204
00:17:35,950 --> 00:17:36,860
قلتُ أنّني لن أخبر أحدًا

205
00:17:49,150 --> 00:17:50,810
هذا لذيذ

206
00:17:50,810 --> 00:17:52,300
إليك واحدًا آخر

207
00:17:55,500 --> 00:17:58,400
أقدّر لك ذلك، لكن كليه أنت

208
00:17:59,450 --> 00:18:04,410
أنا لستُ جائعًا بما أنّني اصطدت 
سمكة وأكلتها خلال اللّيل

209
00:18:06,200 --> 00:18:07,160
حسنًا

210
00:18:07,160 --> 00:18:12,580
حسنًا، سيكتمل الطّوف قريبًا
سأواصل العمل عليه

211
00:18:18,140 --> 00:18:21,810
على أيّ حال، أرى أنّ لديك
الكثير من وقت الفراغ

212
00:18:21,810 --> 00:18:25,880
إنّك تقضين اليوم بطوله معي 
في الأيّام القليلة الماضية

213
00:18:25,880 --> 00:18:27,820
سيقلق عليك أصدقاؤك ووالداك

214
00:18:30,360 --> 00:18:31,440
ليس لديّ والدان

215
00:18:32,280 --> 00:18:33,950
بل لديّ أمّ

216
00:18:33,950 --> 00:18:36,560
لكنّها أبحرت بغرض العمل
عندما كنت طفلة ولم تعد بعد

217
00:18:36,560 --> 00:18:38,530
لذلك لا أتذكّر وجهها حتّى

218
00:18:39,770 --> 00:18:45,450
أحبّ علماء الآثار أولئك، لكنّهم 
لا يضمّونني لأبحاثهم لذلك أظلّ وحيدة

219
00:18:46,190 --> 00:18:50,590
ينعتني الأطفال في البلدة بالبغيضة
بسبب هذا لئلا ألعب معهم

220
00:18:53,120 --> 00:18:56,880
فهمت، أكلتِ فاكهة شيطان إذًا

221
00:18:57,620 --> 00:18:58,710
لست خائفًا؟

222
00:18:58,710 --> 00:19:02,350
اعتدت على الإبحار في الغراند لاين

223
00:19:02,350 --> 00:19:05,020
لذلك رأيت الكثير من آكلي فاكهة الشّيطان

224
00:19:06,120 --> 00:19:07,770
هكذا إذًا

225
00:19:07,770 --> 00:19:09,020
أنا أحسدك

226
00:19:09,020 --> 00:19:11,540
يبدو ذلك مفيدًا جدًّا

227
00:19:18,770 --> 00:19:20,370
ضحكتك غريبة بالفعل

228
00:19:22,150 --> 00:19:24,800
...سواء كانت غريبة أم لا

229
00:19:24,800 --> 00:19:26,210
...اعلمي هذا

230
00:19:26,210 --> 00:19:29,580
ستشعرين بالسّعادة إن ضحكتِ

231
00:19:30,280 --> 00:19:31,270
لماذا؟

232
00:19:31,270 --> 00:19:35,440
تسألين لماذا؟ لأنّ المرء يضحك 
عندما يكون مستمتعًا

233
00:19:35,440 --> 00:19:39,640
ممّا يعني أنّك إن ضحكتِ، فستستمتعين بوقتك

234
00:19:40,540 --> 00:19:44,220
رغم أنّك ما زلت طفلة
يبدو لي أنّك تواجهين وقتًا عصيبًا

235
00:19:44,220 --> 00:19:47,760
لذلك اضحكي، إن كنت تواجهين
وقتًا عصيبًا، اضحكي فحسب

236
00:19:48,610 --> 00:19:50,820
يبدو الضّحك بينما تواجه وقتًا عصيبًا أمرًا غبيًّا

237
00:19:50,820 --> 00:19:52,820
ذلك ليس صحيحًا

238
00:19:54,060 --> 00:19:58,130
هيّا، جرّبي أنت أيضًا

239
00:20:03,280 --> 00:20:04,460
ديريشي

240
00:20:05,250 --> 00:20:08,830
!نعم، نعم! افعليها هكذا

241
00:20:16,390 --> 00:20:18,820
!هذا جيّد! هذا جيّد

242
00:20:24,040 --> 00:20:25,880
معكم مقرّ البحريّة

243
00:20:25,880 --> 00:20:27,990
أجب أيّها الرّئيس سبانداين

244
00:20:27,990 --> 00:20:30,390
يريدون التّكلّم معك أيّها الرّئيس

245
00:20:30,390 --> 00:20:33,410
تجاهلهم فحسب، أنا واثق أنّهم 
يريدون تقريرًا عن الوضع فحسب

246
00:20:33,410 --> 00:20:36,940
سنتّصل بهم عندما نرى السّاحل

247
00:20:36,940 --> 00:20:40,560
...ما يهمني أكانت أوهارا أو أوبرا

248
00:20:40,560 --> 00:20:44,220
لمَ على حضرتي المجيء كل هذه المسافة للأزرق الغربي؟

249
00:20:44,740 --> 00:20:46,530
...سُحقًا

250
00:20:46,530 --> 00:20:48,190
...يا لها من مهمّة تافهة

251
00:21:08,860 --> 00:21:11,570
أخبرني، هل صحيح أنّ سفينة
من البحريّة رست هنا؟

252
00:21:11,570 --> 00:21:13,310
ماذا؟ سفينة من البحريّة؟

253
00:21:13,310 --> 00:21:16,180
نعم، سمعتُ أنّها قد رست
هنا مع بزوغ الفجر

254
00:21:16,180 --> 00:21:18,040
...لماذا قد تأتي البحريّة

255
00:21:18,040 --> 00:21:19,650
لجزيرة معزولة كهذه؟

256
00:21:19,650 --> 00:21:23,450
لكن لم يرَ أحد أيّ جنود عليها

257
00:21:23,450 --> 00:21:24,630
ما هذا؟

258
00:21:24,630 --> 00:21:28,270
،لم يُعثر ولو على شخص واحد
إنّها أشبه بسفينة أشباح

259
00:21:28,270 --> 00:21:30,380
هذا سخيف

260
00:21:31,000 --> 00:21:32,100
أيّها الأستاذ

261
00:21:32,100 --> 00:21:34,340
أيّها الأستاذ كلوفر

262
00:21:36,840 --> 00:21:38,390
هل حدث أمر ما؟

263
00:21:39,200 --> 00:21:43,640
آمل أنّه ليس أمرًا يدعو للقلق، لكن
رست سفينة من البحّرية على السّاحل

264
00:21:43,640 --> 00:21:46,850
ربّما أتوا إلى هنا للتّحقيق، علينا أن نكون
حذرين من باب الحيطة

265
00:21:48,500 --> 00:21:50,170
أعلموا كلّ العلماء

266
00:21:53,360 --> 00:21:55,960
أكملتُ الطّوف

267
00:22:01,620 --> 00:22:03,660
إذًا... ستغادر؟

268
00:22:03,660 --> 00:22:09,400
ما الأمر؟ تعلوا وجهك 
نظرات "أنا وحيدة" بالكامل

269
00:22:10,090 --> 00:22:13,730
بالتّفكير في الأمر، كنت أفكّر 
في إضافة عَلم أو ما شابه

270
00:22:13,730 --> 00:22:16,550
لذلك سأبقى لوقت أطول

271
00:22:23,340 --> 00:22:27,500
الإبحار؟ تريدين الإبحار أيضًا؟

272
00:22:27,500 --> 00:22:28,310
نعم

273
00:22:29,300 --> 00:22:33,280
إنّ أمّي منشغلة ببحثها الأثريّ طوال الوقت

274
00:22:34,130 --> 00:22:36,610
لكن عندما تعود إلى هذه الجزيرة

275
00:22:37,180 --> 00:22:39,570
سأطلب منها أن أبحر معها

276
00:22:39,570 --> 00:22:44,550
لذلك درست بجدّ وتمكّنت أخيرًا 
من أن أصبح عالمة آثار

277
00:22:44,550 --> 00:22:48,410
عالمة آثار؟ رغم أنّك بهذا الصّغر؟

278
00:22:48,940 --> 00:22:49,740
نعم

279
00:22:50,350 --> 00:22:56,080
لكنّك لا تذكرين حتّى وجه أمّك، صحيح؟

280
00:22:56,080 --> 00:22:58,670
نعم... لكنّها تبقى أمّي

281
00:22:59,850 --> 00:23:01,640
أريد رؤيتها

282
00:23:04,050 --> 00:23:05,590
...أخبرني يا ساول

283
00:23:06,180 --> 00:23:10,600
هل تعرف أنّ للعالم مئة سنة فارغة
من التّاريخ يجهلها الكثيرون؟

284
00:23:10,600 --> 00:23:15,010
"نعم. إنّه يُسمّى "القرن الفارغ

285
00:23:15,010 --> 00:23:19,360
يراودني الفضول بشأنه، لكنّ الحكومة 
...تمنع النّاس من البحث فيه، لذا

286
00:23:19,360 --> 00:23:24,950
نعم. سمعت أنّ أمّي تجوب العالم 
وهي تبحث في أمره

287
00:23:24,950 --> 00:23:28,830
لكن لا تخبر أيّ أحد بهذا
بما أنّ الأمر يعدّ جريمة

288
00:23:30,110 --> 00:23:35,590
هـ-هل يعقل أنّها تجوب العالم بحثًا
عن حجارة تُدعى البونغليف؟

289
00:23:36,520 --> 00:23:38,210
أتعرف بشأن البونغليف؟

290
00:23:38,210 --> 00:23:44,180
بالطّبع! لكن لا تتحدّثي عن 
هذا أمام النّاس، مفهوم؟

291
00:23:44,180 --> 00:23:49,640
...ناهيك عن ذكر ترحال أمّك بحثًا عن

292
00:23:50,960 --> 00:23:52,020
ما الخطب؟

293
00:23:52,020 --> 00:23:56,440
روبين... ما هو اسم أمّك؟

294
00:23:56,970 --> 00:23:57,950
أولفيا

295
00:23:59,880 --> 00:24:02,000
إنّه نيكو أولفيا

296
00:24:09,090 --> 00:24:10,340
ساول؟

297
00:24:10,340 --> 00:24:14,260
...روبين هي ابنة أولفيا

298
00:24:14,750 --> 00:24:19,830
...إذًا... فهل هذا المكان
هو جزيرة أوهارا؟

299
00:24:19,830 --> 00:24:20,690
نعم

300
00:24:20,690 --> 00:24:24,190
!هذا فظيع! كلاّ

301
00:24:24,190 --> 00:24:28,530
إذًا فقد انجرفت لأوهارا؟

302
00:24:29,180 --> 00:24:31,030
هذا ليس وقتًا مناسبًا للحديث

303
00:24:31,580 --> 00:24:32,810
روبين -
ماذا؟ -

304
00:24:32,810 --> 00:24:36,900
قد يفاجئك هذا، لكن أنصتي إليّ جيّدًا

305
00:24:36,900 --> 00:24:41,210
ثمّة سفن من البحريّة متّجهة إلى أوهارا الآن

306
00:24:41,760 --> 00:24:43,640
البحريّة؟ لماذا؟

307
00:24:43,640 --> 00:24:46,540
بهدف القضاء على العلماء الّذين فيها

308
00:24:48,250 --> 00:24:49,800
القضاء عليهم؟

309
00:24:50,500 --> 00:24:52,980
...لا تقولي أنّك

310
00:24:52,980 --> 00:24:53,900
...هذه كذبة

311
00:24:53,900 --> 00:24:56,290
لا تقولي للحكومة أنّك عالمة

312
00:24:56,290 --> 00:24:57,000
...هذه كذبة

313
00:24:57,010 --> 00:24:58,390
أتفهمين كلامي؟

314
00:24:58,760 --> 00:25:00,090
هذه كذبة

315
00:25:00,090 --> 00:25:03,560
!إنّها الحقيقة! ما كنت لأكذب عليك

316
00:25:03,560 --> 00:25:06,940
اذهبي للبلدة الآن ولاحظي 
إن حدث أيّ شيء غريب

317
00:25:06,940 --> 00:25:11,050
من المحتمل أن تكون أمّك قد عادت أيضًا

318
00:25:19,500 --> 00:25:21,460
مرّ وقت طويل يا رفاق

319
00:25:21,460 --> 00:25:22,600
...أولفيا

320
00:25:22,580 --> 00:25:23,550
...أولفيا-سان

321
00:25:23,550 --> 00:25:25,750
إذًا فأنت من أتت على سفينة البحريّة تلك

322
00:25:25,750 --> 00:25:27,420
...ظننّا أنّ البحريّة قد قبضت عليك

323
00:25:35,320 --> 00:25:38,590
آسفة لعودتي حاملة أخبارًا سيّئة

324
00:25:38,590 --> 00:25:40,350
لكنّ ما قلتُه هي الحقيقة

325
00:25:40,350 --> 00:25:44,520
إذًا فقد وضعت الحكومة 
عينيها على أوهارا أخيرًا؟

326
00:25:45,500 --> 00:25:47,010
هل قرأتم الصّحيفة؟

327
00:25:47,010 --> 00:25:51,870
لقد قُضي على فريق بحث البونغليف 
الّذي انطلق من أوهارا قبل ستّ سنوات

328
00:25:51,870 --> 00:25:56,670
...جميعهم ما عداي أنا
...وحوالي 33 عضوًا منه

329
00:25:56,670 --> 00:25:59,280
تعرّضوا للأسر مؤقّتًا

330
00:25:59,280 --> 00:26:03,920
راجعت الحكومة مقتنيات زملائي العلماء

331
00:26:03,920 --> 00:26:06,970
واكتشفت أنّنا أتينا من أوهارا

332
00:26:08,160 --> 00:26:13,100
هذا عمل لا يغتفر، لا أصدّق أنّ هذه 
الجزيرة في خطر بسببنا

333
00:26:13,100 --> 00:26:16,860
!توقّفي! إنّها ليست غلطة أيّ أحد

334
00:26:16,860 --> 00:26:21,000
إنّ من خاضوا غمار البحر وأولئك الّذين 
بقوا هنا... جميعنا فريق واحد

335
00:26:21,000 --> 00:26:24,310
كان أنتم من واجه وقتًا عصيبًا

336
00:26:25,380 --> 00:26:27,060
جعلناكم تمرّون بمحنة عويصة

337
00:26:28,810 --> 00:26:29,980
...أيّها الأستاذ

338
00:26:30,460 --> 00:26:34,700
إنّ أوهارا مكان يجتمع فيه العلماء 
الموهوبين من أنحاء العالم

339
00:26:34,700 --> 00:26:37,240
ويواصلون دراسة التّاريخ

340
00:26:37,240 --> 00:26:40,120
لطالما اعتبرتنا الحكومة تهديدًا

341
00:26:40,710 --> 00:26:43,930
لا بدّ أنّهم يعتقدون أنّهم أوقعوا بنا أخيرًا

342
00:26:43,930 --> 00:26:46,050
لن يفوّتوا هذه الفرصة أبدًا

343
00:26:46,050 --> 00:26:50,460
نعم، لكنّنا تمكّنّا من الحصول
على تلك المعلومة دون تأخير

344
00:26:50,460 --> 00:26:54,690
وفي النّهاية، سيُقضى على كلّ 
من يدّعي أنّه عالم في أوهارا

345
00:26:54,690 --> 00:26:58,480
لذلك غادروا أوهارا جميعًا في الحال

346
00:26:58,480 --> 00:27:00,540
صحيح

347
00:27:00,540 --> 00:27:05,450
على الأرجح أنّنا لن نستطيع هذه المرة
من تفادي تحقيقهم ...كما نفعل في العادة

348
00:27:05,940 --> 00:27:09,540
إن كانوا يحاولون قتلنا

349
00:27:09,540 --> 00:27:10,870
...لذلك عليكم الإسراع

350
00:27:10,870 --> 00:27:12,820
...لكن يا أولفيا

351
00:27:13,520 --> 00:27:17,630
لا يمكنني الهرب تاركًا كنز البشريّة هذا خلفي

352
00:27:17,630 --> 00:27:19,130
يجب أن تعلمي ذلك

353
00:27:19,130 --> 00:27:22,000
وكذلك نشعر نحن أيضًا يا أولفيا

354
00:27:22,650 --> 00:27:23,920
...يا رفاق

355
00:27:23,920 --> 00:27:26,670
لا ندري ما الّذي تنوي الحكومة فعله

356
00:27:26,670 --> 00:27:30,420
لكن إن هربنا، فلن يظلّ من سيحمي 
التّاريخ النّفيس الّذي هنا

357
00:27:30,420 --> 00:27:33,380
سنبذل كلّ ما نستطيع، كما فعلنا دائمًا

358
00:27:33,380 --> 00:27:35,230
...والأهمّ من ذلك

359
00:27:35,750 --> 00:27:38,150
لا بدّ من وجود أمر يثقل تفكيرك

360
00:27:39,200 --> 00:27:41,400
لكن لا أستطيع رؤيتها

361
00:27:42,440 --> 00:27:46,360
اتّخذي قرارك يا أولفيا، هل ستصعدين 
على متن السّفينة أم لا؟

362
00:27:46,360 --> 00:27:49,160
إن كنت متعلّقة بطفلتك
فلا تبحري معنا

363
00:27:49,160 --> 00:27:51,080
إن كان هذا بشأن عمل زوجك 
...غير المنتهي، فسوف

364
00:27:52,140 --> 00:27:53,530
!كلاّ! سأذهب

365
00:27:53,530 --> 00:27:59,120
أنا عالمة من أوهارا، لا يمكنني 
التّخلّي عن إرادة من سبقونا

366
00:28:00,200 --> 00:28:01,700
آسفة يا روبين

367
00:28:01,700 --> 00:28:05,630
سأحلّ كلّ الألغاز وأعود بكلّ تأكيد

368
00:28:11,100 --> 00:28:16,000
أمّي... أين أمّي؟ إلى أين ذهبت أمّي؟

369
00:28:16,000 --> 00:28:21,190
،قرّرت أمّك الإبحار بغرض العمل
ستبقين معنا هنا لوهلة

370
00:28:21,190 --> 00:28:24,270
!أنت مزعجة! اصمتي وإلاّ ضربتك

371
00:28:24,270 --> 00:28:26,320
توقّفي، عمرها سنتان فحسب

372
00:28:26,320 --> 00:28:28,140
ابنتنا في نفس العمر أيضًا

373
00:28:28,140 --> 00:28:30,700
لا أهتمّ إن كانت ابنة أختك 
...الكبرى أو مهما كان

374
00:28:30,700 --> 00:28:34,060
كيف تجرؤ على حمل عبء كهذا؟

375
00:28:37,160 --> 00:28:40,130
من هناك؟ لا تتحرّك

376
00:28:41,710 --> 00:28:44,680
...أ-أنا... كنت

377
00:28:48,110 --> 00:28:49,530
أنا آسفة

378
00:28:51,470 --> 00:28:54,940
أعلميني عندما تريدين قراءة الكتب

379
00:28:54,940 --> 00:28:57,900
...لكن لا مال لديّ

380
00:28:57,900 --> 00:29:02,420
ليس عليك دفع أيّ شيء
بإمكانك قراءتها جميعها بالمجّان

381
00:29:02,420 --> 00:29:03,340
بالمجّان؟

382
00:29:03,340 --> 00:29:06,990
نعم، فهذه أفضل مكتبة في العالم

383
00:29:06,990 --> 00:29:08,100
الأفضل في العالم؟

384
00:29:08,100 --> 00:29:08,950
هذا صحيح

385
00:29:08,950 --> 00:29:11,890
بالمناسبة، أنت ابنة أولفيا، صحيح؟

386
00:29:13,010 --> 00:29:14,330
هل تحبّين الكتب؟

387
00:29:14,330 --> 00:29:15,820
نعم

388
00:29:17,720 --> 00:29:20,760
تبدو مثلك تمامًا عندما كنت طفلة

389
00:29:20,760 --> 00:29:23,910
إنّ عبقريّتها نادرة كما كنتِ أنت في سنّها

390
00:29:24,580 --> 00:29:27,260
...ما دامت بخير

391
00:29:28,420 --> 00:29:31,400
اخترت هذا كعمل لي. لذلك 
عليّ التّخلّي عن تعلّقي بها

392
00:29:31,400 --> 00:29:35,350
"بما أنّني لا أستطيع جعلها "ابنة مجرمة

393
00:29:35,350 --> 00:29:39,070
أيّها الأستاذ كلوفر، أتت هذه المرّة 
سفينة يعلوها علم حكومة العالم

394
00:29:39,070 --> 00:29:43,220
أتت سفينة من الحكومة كلّ 
...هذه المسافة للأزرق الغربيّ

395
00:29:43,220 --> 00:29:46,990
يبدو الأمر خطيرًا بالفعل

396
00:29:48,950 --> 00:29:50,990
اسمعوا جميعًا

397
00:29:50,990 --> 00:29:53,920
أنا وأنتم لسنا زملاء علم أو معارف

398
00:29:55,920 --> 00:29:59,620
...ضعوا ذلك حلقة في آذانكم
مهما كان ما سيحدث

399
00:29:59,620 --> 00:30:02,540
انتظري يا أولفيا، ما الّذي ستفعلينه؟

400
00:30:02,540 --> 00:30:05,850
أنت، أعلم المقرّ أنّنا 
وصلنا لوجهتنا أخيرًا

401
00:30:07,230 --> 00:30:09,520
!هيّا، هيّا، هيّا! واصلوا التّقدّم

402
00:30:10,030 --> 00:30:12,490
يا إلهي... كم هذا مزعج

403
00:30:13,850 --> 00:30:16,830
على أيّ حال، من الأفضل أن تمنحني
هذه المهمّة ترقية

404
00:30:16,830 --> 00:30:20,710
أنتم، أحضروا كلّ العلماء وقيّدوهم

405
00:30:20,710 --> 00:30:21,450
حاضر

406
00:30:21,450 --> 00:30:23,330
ما الّذي يحدث؟

407
00:30:23,330 --> 00:30:25,640
امرأة ببندقيّة تركض في الأرجاء

408
00:30:44,590 --> 00:30:49,060
!يا إلهي! أنا جدّ آسف يا روبين

409
00:30:49,060 --> 00:30:50,000
يا نائب الأميرال كوزان

410
00:30:50,000 --> 00:30:52,490
ماذا؟ ماذا هنالك؟

411
00:30:52,490 --> 00:30:56,030
تمّ إبلاغنا أنّ الرّئيس سبانداين 
من السّي بي 9 قد وصل لأوهارا

412
00:30:56,030 --> 00:31:02,000
